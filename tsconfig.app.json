{
  "compilerOptions": {
    "composite": true, "target": "ES2022", "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext", "moduleResolution": "bundler", "jsx": "react-jsx",
    "strict": true, "noEmit": false, "emitDeclarationOnly": true, "outDir": "node_modules/.tsbuild/app",
    "skipLibCheck": true, "types": ["vite/client"]
  },
  "include": ["src", "shared", "test"]
}
